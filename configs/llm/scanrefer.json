{
  "benchmark": "scanrefer",
  "data": {
    "root": "data/Scanrefer",
    "splits": {
      "train": "ScanRefer_filtered_train.json",
      "val": "ScanRefer_filtered_val.json",
      "all": "ScanRefer_filtered.json"
    },
    "id_offset": 1
  },
  "graph": {
    "default": "oneformer",
    "options": {
      "gt": "results/graphs/scannet200_gt/scenes",
      "oneformer": "results/graphs/scannet200_oneformer/scenes"
    },
    "max_objects": 120,
    "neighbor_cap": 4,
    "use_edges": true,
    "use_attributes": true,
    "use_colors": false,
    "use_size": true
  },
  "model": {
    "id": "Qwen/Qwen3-4B-Instruct-2507",
    "dtype": "auto",
    "quantization": "none",
    "tensor_parallel_size": 1,
    "max_model_len": 8192,
    "gpu_memory_utilization": 0.5,
    "swap_space_gb": 4,
    "enable_prefix_caching": true,
    "trust_remote_code": false,
    "enforce_eager": false
  },
  "generation": {
    "batch_size": 1,
    "temperature": 0.1,
    "top_p": 0.9,
    "max_tokens": 64,
    "n": 1
  },
  "prompt": {
    "instruction": "Instruction: Select the single object id from the list that best matches the query for an indoor scene. Return one-line JSON with fields prediction and no extra text.",
    "expects_json": true
  },
  "structured_output": {
    "enabled": true,
    "allow_rationale": false,
    "json": {
      "type": "object",
      "properties": {
        "prediction": {
          "type": "integer"
        }
      },
      "required": [
        "prediction"
      ],
      "additionalProperties": false
    },
    "disable_additional_properties": true,
    "disable_fallback": true
  },
  "evaluation": {
    "save_per_query": false,
    "compute_metrics": true
  },
  "output": {
    "output_path": ""
  }
}